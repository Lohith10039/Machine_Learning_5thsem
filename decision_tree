import math
import pandas as pd

# 1. Read CSV from the current working directory
df = pd.read_csv('/dataset.csv')

print("--- DATASET ---")
print(df)
print("----------------\n")


# 2. Function to calculate Entropy
def entropy(column):
    values = column.value_counts()
    total = len(column)
    e = 0

    for count in values:
        p = count / total
        e -= p * math.log2(p)

    return e


# Print overall target entropy (Using "Buys" column)
print(f"Target Entropy P(Buys): {entropy(df['class']):.4f}\n")


# 3. Function to calculate Information Gain
def information_gain(df, feature, target):
    total_entropy = entropy(df[target])
    values = df[feature].unique()
    weighted_entropy = 0

    for value in values:
        subset = df[df[feature] == value]
        weight = len(subset) / len(df)
        weighted_entropy += weight * entropy(subset[target])

    gain = total_entropy - weighted_entropy
    return gain


# Print information gain for initial features
print("--- INITIAL INFORMATION GAINS ---")
features = [col for col in df.columns if col != "class"]
for feature in features:
    print(f"{feature}: {information_gain(df, feature, 'class'):.4f}")
print("---------------------------------\n")


# 4. Recursive Decision Tree Builder (ID3)
def build_tree(df, target):
    # Check if all rows belong to one class
    if len(df[target].unique()) == 1:
        return df[target].iloc[0]

    # Check if only target column is left
    if len(df.columns) == 1:
        return df[target].mode()[0]

    feature_cols = [col for col in df.columns if col != target]
    gains = {}

    for feat in feature_cols:
        gains[feat] = information_gain(df, feat, target)

    best_feature = max(gains, key=gains.get)
    tree = {best_feature: {}}

    for value in df[best_feature].unique():
        subset = df[df[best_feature] == value]

        subtree = build_tree(subset.drop(columns=[best_feature]), target)

        tree[best_feature][value] = subtree

    return tree


# 5. Function to Print the Tree
def print_tree(tree, indent=""):
    if not isinstance(tree, dict):
        print(indent + "->", tree)
        return

    for feature in tree:
        print(indent + feature)

        for value in tree[feature]:
            print(indent + "|--", value)
            print_tree(tree[feature][value], indent + "    ")


# 6. Build & Print Decision Tree
decision_tree = build_tree(df, "class")

print("--- DECISION TREE STRUCTURE ---")
print_tree(decision_tree)
